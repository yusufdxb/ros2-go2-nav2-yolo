<!-- GO2 Robot Description with RGB-D Camera Plugin. Based on: https://github.com/arjun-sadananda/go2_nav2_ros2. Added: Gazebo RGB-D camera plugin for YOLOv8 + depth. Full mesh files and full URDF come from the upstream go2_nav2_ros2 repo. -->
<robot name="go2" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include base GO2 description from upstream -->
  <!-- xacro:include filename="$(find go2_description)/xacro/go2_base.xacro"/ -->

  <!-- RGB-D Camera — mounted on GO2 head -->

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- Mount camera on head / trunk_link — adjust xyz to match GO2 head position -->
  <joint name="camera_joint" type="fixed">
    <parent link="trunk"/>   <!-- Change to correct GO2 base link name -->
    <child link="camera_link"/>
    <!-- Position: front of robot, at head height, facing forward -->
    <origin xyz="0.28 0.0 0.12" rpy="0 0.15 0"/>
  </joint>

  <!-- Optical frame (ROS convention: z forward, x right, y down) -->
  <link name="camera_color_optical_frame"/>
  <joint name="camera_color_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Depth camera sensor — requires LIBGL_DRI3_DISABLE=1 passed to gzserver via gazebo_launch.py for OGRE to init correctly. -->
  <gazebo reference="camera_link">
    <sensor type="depth" name="go2_camera">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>8.0</far>
        </clip>
      </camera>
      <plugin name="go2_camera_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/go2</namespace>
          <remapping>image_raw:=camera/image_raw</remapping>
          <remapping>image_depth:=camera/depth/image_raw</remapping>
          <remapping>camera_info:=camera/camera_info</remapping>
          <remapping>depth_camera_info:=camera/depth/camera_info</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_color_optical_frame</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>8.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

</robot>
