<!-- GO2 Robot Description with RGB-D Camera Plugin
     Based on: https://github.com/arjun-sadananda/go2_nav2_ros2
     Added: Gazebo RGB-D camera plugin for YOLOv8 + depth

     Full mesh files and full URDF come from the upstream go2_nav2_ros2 repo.
     Clone it and use go2_description from there — this file shows
     the camera xacro addition to include in go2_robot.xacro.
-->
<robot name="go2" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include base GO2 description from upstream -->
  <!-- xacro:include filename="$(find go2_description)/xacro/go2_base.xacro"/ -->

  <!-- ══════════════════════════════════════════════════════
       RGB-D Camera — mounted on GO2 head
       Add this block to your go2_robot.xacro
       ══════════════════════════════════════════════════════ -->

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.09 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.072"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
  </link>

  <!-- Mount camera on head / trunk_link — adjust xyz to match GO2 head position -->
  <joint name="camera_joint" type="fixed">
    <parent link="trunk"/>   <!-- Change to correct GO2 base link name -->
    <child link="camera_link"/>
    <!-- Position: front of robot, at head height, facing forward -->
    <origin xyz="0.28 0.0 0.12" rpy="0 0.15 0"/>
  </joint>

  <!-- Optical frame (ROS convention: z forward, x right, y down) -->
  <link name="camera_color_optical_frame"/>
  <joint name="camera_color_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <link name="camera_depth_optical_frame"/>
  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- Camera Gazebo sensor plugins are defined in the world file (demo_world.world)
       as a standalone model attached to the robot via a joint, not in the URDF.
       Embedding sensor plugins in the URDF causes gzserver to crash in headless
       mode because libgazebo_ros_camera.so requires a rendering scene that is
       not initialised until gzclient connects. The links/joints above are kept
       so the TF tree is complete for the navigator node. -->

</robot>
